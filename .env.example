# Copy to .env and fill in values

# Required: Used for real LLM-based intent parsing (falls back to rule-based if missing)
OPENAI_API_KEY=sk-...

# The public URL where this API is deployed (for trace links returned to Convai)
# For local dev: http://localhost:8000
# For production: https://your-deployed-url.com
API_BASE_URL=http://localhost:8000
